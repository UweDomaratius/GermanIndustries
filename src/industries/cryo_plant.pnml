switch(FEAT_INDUSTRIES, SELF, cryo_plant_update_production_according_to_power,
	[STORE_TEMP(LOAD_TEMP(TEMP_REGISTER_PRODUCT_1)+LOAD_TEMP(TEMP_REGISTER_PRODUCT_2), TEMP_REGISTER_PRODUCTION_AMOUNT),
	 limit_production_due_to_power(),
	 // scale production for each product separately: full production is PRODUCT_1+PRODUCT_2, reduced production is PRODUCTION_AMOUNT
	 STORE_TEMP(LOAD_TEMP(TEMP_REGISTER_PRODUCT_1)*LOAD_TEMP(TEMP_REGISTER_PRODUCTION_AMOUNT) / (LOAD_TEMP(TEMP_REGISTER_PRODUCT_1)+LOAD_TEMP(TEMP_REGISTER_PRODUCT_2)), TEMP_REGISTER_PRODUCT_1),
	 STORE_TEMP(LOAD_TEMP(TEMP_REGISTER_PRODUCT_2)*LOAD_TEMP(TEMP_REGISTER_PRODUCTION_AMOUNT) / (LOAD_TEMP(TEMP_REGISTER_PRODUCT_1)+LOAD_TEMP(TEMP_REGISTER_PRODUCT_2)), TEMP_REGISTER_PRODUCT_2),
	])
