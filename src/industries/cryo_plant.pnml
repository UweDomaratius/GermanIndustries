//////////////////////////////////////////////////////////////////////////////
// graphics choice switch chain
//////////////////////////////////////////////////////////////////////////////

switch(FEAT_INDUSTRYTILES, SELF, cryo_plant_switch_graphics_layout_1, relative_pos) {
	relative_coord(0, 0): cryo_plant_spritelayout_large_shed;
	relative_coord(0, 1): cryo_plant_spritelayout_horizontal_tanks;
	relative_coord(1, 0): cryo_plant_spritelayout_purification_unit;
	relative_coord(1, 1): cryo_plant_spritelayout_separation_tower;
	relative_coord(2, 0): cryo_plant_spritelayout_horizontal_tanks;
	relative_coord(2, 1): cryo_plant_spritelayout_empty;
	relative_coord(3, 0): cryo_plant_spritelayout_storage_tank_blue;
	relative_coord(3, 1): cryo_plant_spritelayout_storage_tank_yellow;
	return 0; // a default is needed, but should never be reached, layout definitions are explicit
}
switch(FEAT_INDUSTRYTILES, SELF, cryo_plant_switch_graphics_layout_2, relative_pos) {
	relative_coord(0, 0): cryo_plant_spritelayout_storage_tank_blue;
	relative_coord(0, 1): cryo_plant_spritelayout_storage_tank_yellow;
	relative_coord(1, 0): cryo_plant_spritelayout_large_shed;
	relative_coord(1, 1): cryo_plant_spritelayout_empty;
	relative_coord(2, 0): cryo_plant_spritelayout_purification_unit;
	relative_coord(2, 1): cryo_plant_spritelayout_separation_tower;
	relative_coord(3, 0): cryo_plant_spritelayout_horizontal_tanks;
	relative_coord(3, 1): cryo_plant_spritelayout_horizontal_tanks;
	return 0; // a default is needed, but should never be reached, layout definitions are explicit
}
switch(FEAT_INDUSTRYTILES, SELF, cryo_plant_switch_graphics_layout_3, relative_pos) {
	relative_coord(0, 0): cryo_plant_spritelayout_large_shed;
	relative_coord(0, 1): cryo_plant_spritelayout_horizontal_tanks;
	relative_coord(0, 2): cryo_plant_spritelayout_horizontal_tanks;
	relative_coord(0, 3): cryo_plant_spritelayout_storage_tank_yellow;
	relative_coord(1, 0): cryo_plant_spritelayout_purification_unit;
	relative_coord(1, 1): cryo_plant_spritelayout_separation_tower;
	relative_coord(1, 2): cryo_plant_spritelayout_empty;
	relative_coord(1, 3): cryo_plant_spritelayout_storage_tank_blue;
	return 0; // a default is needed, but should never be reached, layout definitions are explicit
}

switch(FEAT_INDUSTRYTILES, SELF, cryo_plant_switch_graphics_layout_4, relative_pos) {
	relative_coord(0, 0): cryo_plant_spritelayout_storage_tank_yellow;
	relative_coord(0, 1): cryo_plant_spritelayout_large_shed;
	relative_coord(0, 2): cryo_plant_spritelayout_purification_unit;
	relative_coord(0, 3): cryo_plant_spritelayout_separation_tower;
	relative_coord(1, 0): cryo_plant_spritelayout_storage_tank_blue;
	relative_coord(1, 1): cryo_plant_spritelayout_empty;
	relative_coord(1, 2): cryo_plant_spritelayout_horizontal_tanks;
	relative_coord(1, 3): cryo_plant_spritelayout_horizontal_tanks;
	return 0; // a default is needed, but should never be reached, layout definitions are explicit
}
switch(FEAT_INDUSTRYTILES, SELF, cryo_plant_switch_graphics_layout_5, relative_pos) {
	relative_coord(0, 0): cryo_plant_spritelayout_large_shed;
	relative_coord(0, 1): cryo_plant_spritelayout_empty;
	relative_coord(0, 2): cryo_plant_spritelayout_storage_tank_yellow;
	relative_coord(1, 0): cryo_plant_spritelayout_purification_unit;
	relative_coord(1, 1): cryo_plant_spritelayout_separation_tower;
	relative_coord(1, 2): cryo_plant_spritelayout_storage_tank_blue;
	relative_coord(2, 0): cryo_plant_spritelayout_horizontal_tanks;
	relative_coord(2, 1): cryo_plant_spritelayout_horizontal_tanks;
	return 0; // a default is needed, but should never be reached, layout definitions are explicit
}

switch(FEAT_INDUSTRYTILES, PARENT, cryo_plant_switch_graphics_layout, layout_num) {
    1: cryo_plant_switch_graphics_layout_1;
    2: cryo_plant_switch_graphics_layout_2;
    3: cryo_plant_switch_graphics_layout_3;
	4: cryo_plant_switch_graphics_layout_4;
	5: cryo_plant_switch_graphics_layout_5;
    cryo_plant_switch_graphics_layout_1; // default
}

switch(FEAT_INDUSTRYTILES, SELF, cryo_plant_switch_graphics_construction_state, construction_state) {
    0..2: spritelayout_default_construction_states;
    cryo_plant_switch_graphics_layout; // default
}

switch (FEAT_INDUSTRYTILES, SELF, cryo_plant_switch_graphics,
	[switch_tile_fences(),switch_terrain_sprite(),switch_graphics_init_temp_registers()
	]) {
    cryo_plant_switch_graphics_construction_state;
}

//////////////////////////////////////////////////////////////////////////////
// location checks
//////////////////////////////////////////////////////////////////////////////
// This check works as follows: calculate height of the northernmost tile of the industry and add 0, 1 or 2 for flat, slope. steep slope
// Do the same for the current tile and compare the results. If the result is equal, the terrain is effectively flat
// and industry can be placed.
// It just looks weird due to the stacked ternary operators needed here
switch (FEAT_INDUSTRYTILES, SELF, cryo_plant_switch_tile_location_check2,
			(nearby_tile_height(-relative_x, -relative_y) + 
			(nearby_tile_slope(-relative_x, -relative_y)== SLOPE_FLAT ? 0 : nearby_tile_slope(-relative_x, -relative_y) == bitmask(IS_STEEP_SLOPE) ? 2 : 1)) 
			== 
			(nearby_tile_height(0, 0) + (nearby_tile_slope(0, 0) == SLOPE_FLAT ? 0 : nearby_tile_slope(0, 0) == bitmask(IS_STEEP_SLOPE) ? 2 : 1))
			) {
	1: return CB_RESULT_LOCATION_ALLOW;
	return CB_RESULT_LOCATION_DISALLOW;
}

switch (FEAT_INDUSTRYTILES, SELF, cryo_plant_switch_tile_location_check,
	is_funded_or_prospected() || (generation_not_forbidden_by_param() && not_next_to_industry() && not_next_to_buildings()))
{
	1: cryo_plant_switch_tile_location_check2;
	return CB_RESULT_LOCATION_DISALLOW;
}

//////////////////////////////////////////////////////////////////////////////
// industry tile and layout definition
//////////////////////////////////////////////////////////////////////////////
item(FEAT_INDUSTRYTILES, cryo_plant_tile, INDUSTRY_TILE_ID_CRYO_PLANT) {
	property {
		substitute:         0;
        land_shape_flags:   0;
        special_flags: bitmask(INDTILE_FLAG_ACCEPT_ALL);
        animation_triggers: bitmask();
	}
	graphics {
		tile_check: cryo_plant_switch_tile_location_check;
		cryo_plant_switch_graphics;
	}
}

tilelayout cryo_plant_industry_layout_1_tilelayout {
	0, 0: cryo_plant_tile;
	0, 1: cryo_plant_tile;
	1, 0: cryo_plant_tile;
	1, 1: cryo_plant_tile;
	2, 0: cryo_plant_tile;
	2, 1: cryo_plant_tile;
	3, 0: cryo_plant_tile;
	3, 1: cryo_plant_tile;
}
