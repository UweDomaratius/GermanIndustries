if (param_extension_ammonia && (!param_extension_production_boost || !param_electricity_needed)) {
	item(FEAT_INDUSTRIES, cryo_plant, INDUSTRY_ID_CRYO_PLANT) {
		property {
			substitute: 0;
			map_colour: 148;
			life_type: IND_LIFE_TYPE_PROCESSING;
			min_cargo_distr: 1;
			layouts: [cryo_plant_industry_layout_1_tilelayout,cryo_plant_industry_layout_2_tilelayout,cryo_plant_industry_layout_3_tilelayout,cryo_plant_industry_layout_4_tilelayout,cryo_plant_industry_layout_5_tilelayout];
			spec_flags: bitmask(IND_FLAG_LONG_CARGO_TYPE_LISTS);
			conflicting_ind_types: [];
			random_sound_effects: [];
			name: string(STR_IND_CRYO_PLANT);
			prob_map_gen: 7;
			prob_in_game: 4;
			prospect_chance: 0.75;
			fund_cost_multiplier: 45;
			remove_cost_multiplier: 0;
			cargo_types: [produce_cargo("O2__",0), produce_cargo("N2__",0)];
			nearby_station_name: string(STR_STATION, string(STR_TOWN),string(STR_STATION_CRYO_PLANT));
		}
	
		graphics {
			construction_probability: cryo_plant_switch_check_availability;
			produce_cargo_arrival:    empty_produce; 
			produce_256_ticks:        cryo_plant_switch_produce;
			monthly_prod_change:      cryo_plant_switch_monthly_prod_change;
			//random_prod_change:       cryo_plant_switch_prod_change;
			build_prod_change:        cryo_plant_switch_prod_change_build;
			location_check:           cryo_plant_switch_location_check_industry_distance;
			extra_text_fund:          cryo_plant_switch_extra_text_fund;
			extra_text_industry:      cryo_plant_switch_extra_text;
		}
	}
}

if (param_extension_ammonia && param_extension_production_boost && param_electricity_needed) {
	item(FEAT_INDUSTRIES, cryo_plant, INDUSTRY_ID_CRYO_PLANT) {
		property {
			substitute: 0;
			map_colour: 148;
			life_type: IND_LIFE_TYPE_PROCESSING;
			min_cargo_distr: 1;
			layouts: [cryo_plant_industry_layout_1_tilelayout,cryo_plant_industry_layout_2_tilelayout,cryo_plant_industry_layout_3_tilelayout,cryo_plant_industry_layout_4_tilelayout,cryo_plant_industry_layout_5_tilelayout];
			spec_flags: bitmask(IND_FLAG_LONG_CARGO_TYPE_LISTS);
			conflicting_ind_types: [];
			random_sound_effects: [];
