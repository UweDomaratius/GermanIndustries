	get_construction_probability;
}

switch(FEAT_INDUSTRIES, SELF, cryo_plant_switch_extra_text_electricity_with_warning, 
	[
	 STORE_TEMP(city_get_power_available(), TEMP_REGISTER_POWER_AVAILABLE),
	 STORE_TEMP(string(STR_INDUSTRY_NOT_ENOUGH_POWER) | string(STR_INDUSTRY_ELECTRICITY_TEXT) << 16, TEMP_REGISTER_EXTRA_TEXT_ARG0),
	 STORE_TEMP(LOAD_PERM(PERM_REGISTER_POWER_DEMAND), TEMP_REGISTER_EXTRA_TEXT_ARG1),
	 STORE_TEMP(string(STR_INDUSTRY_PREREQ_INCREASE_PRODUCTION) | (param_primary_production_increase_transport_percentage < 50 ? 60 : param_primary_production_increase_transport_percentage) << 16, TEMP_REGISTER_EXTRA_TEXT_ARG2),
	])
{
	return string(STR_CONCAT_WITH_LINEBREAK);
}

switch(FEAT_INDUSTRIES, SELF, cryo_plant_switch_extra_text_electricity_without_warning, 
	[
	 STORE_TEMP(city_get_power_available(), TEMP_REGISTER_POWER_AVAILABLE),
	 STORE_TEMP(LOAD_PERM(PERM_REGISTER_POWER_DEMAND), TEMP_REGISTER_EXTRA_TEXT_ARG0),
	 STORE_TEMP(string(STR_INDUSTRY_PREREQ_INCREASE_PRODUCTION) | (param_primary_production_increase_transport_percentage < 50 ? 60 : param_primary_production_increase_transport_percentage) << 16, TEMP_REGISTER_EXTRA_TEXT_ARG1),
	])
{
	return string(STR_INDUSTRY_ELECTRICITY_TEXT);
}

switch(FEAT_INDUSTRIES, SELF, cryo_plant_switch_extra_text_electricity, [LOAD_PERM(PERM_REGISTER_PRODUCTION_LIMITED_BY) & 0x2])
{
