	 STORE_TEMP(LOAD_PERM(PERM_REGISTER_MAXIMUM_PRODUCTION_AMOUNT1) * LOAD_TEMP(TEMP_REGISTER_PRODUCTIVITY_SCALE) / 100, TEMP_REGISTER_PRODUCT_2),
